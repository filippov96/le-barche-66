---
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Hero from '../../components/Hero.astro';
import Intro from '../../components/Intro.astro';
import Amenities from '../../components/Amenities.astro';
import Apartments from '../../components/Apartments.astro';
import Location from '../../components/Location.astro';
import Experience from '../../components/Experience.astro';
import Reviews from '../../components/Reviews.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import Footer from '../../components/Footer.astro';
import i18n from '../../i18n/index';

const t = i18n.de;
---
<Base
  lang="de"
  title="Le Barche 66 — Moderne Apartments in Venedig Mestre"
  description="Fünf moderne, renovierte Apartments im Herzen von Venedig Mestre. 15 Minuten vom Markusplatz, mit privatem Parkplatz."
>
  <Topbar t={t} lang="de" />
  <main>
    <Hero t={t} />
    <Intro t={t} />
    <Amenities t={t} />
    <Apartments t={t} />
    <Location t={t} />
    <Experience t={t} />
    <Reviews t={t} />
    <BookingCTA t={t} />
  </main>
  <Footer t={t} />
</Base>
