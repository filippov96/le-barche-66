---
import '../styles/global.css';
import type { Locale } from '../i18n/index';

interface Props {
  lang: Locale;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const SITE = 'https://filippov96.github.io';

const langUrls = {
  it: `${SITE}${BASE}`,
  en: `${SITE}${BASE}en/`,
  de: `${SITE}${BASE}de/`,
};
const canonical = langUrls[lang];
---
<!doctype html>
<html lang={lang} data-palette="lagoon">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="it" href={langUrls.it} />
  <link rel="alternate" hreflang="en" href={langUrls.en} />
  <link rel="alternate" hreflang="de" href={langUrls.de} />
  <link rel="alternate" hreflang="x-default" href={langUrls.it} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&display=swap" />
  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>
  <!-- CookieYes -->
  <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/390a5b48403ee4e6e537cd13da7a9352/script.js"></script>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-G62EJSHL8H"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-G62EJSHL8H');
  </script>
</head>
<body>
  <slot />
</body>
</html>
